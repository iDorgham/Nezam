#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged=()
while IFS= read -r f; do
  staged+=("$f")
done < <(git diff --cached --name-only --diff-filter=ACM)
needs_sync=false
for f in "${staged[@]}"; do
  case "$f" in
    .cursor/commands/*|.cursor/agents/*|.cursor/skills/*|.cursor/rules/*)
      needs_sync=true
      break
      ;;
  esac
done

if [[ "$needs_sync" == true ]]; then
  if command -v pnpm >/dev/null 2>&1; then
    pnpm run ai:sync
  else
    npm run ai:sync
  fi
  for root in AGENTS.md CLAUDE.md GEMINI.md QWEN.md; do
    [[ -e "$root" ]] && git add -- "$root"
  done
  for dir in .claude .codex .opencode .antigravity .gemini .qwen .kilocode; do
    [[ -d "$dir" ]] && git add -- "$dir"
  done
fi
