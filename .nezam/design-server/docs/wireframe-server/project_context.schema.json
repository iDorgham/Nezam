{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "nezam:wireframe-server:project_context:1.0.0",
  "title": "NEZAM Wireframe Server — Project Context (Agent → Server)",
  "description": "Generated by the Planning Agent from PRD + IA + CONTENT specs. Read by the wireframe server on boot to pre-populate the canvas with AI-suggested layouts, sitemap, and design tokens.",

  "type": "object",
  "required": ["meta", "canvas_mode", "sitemap", "pages", "design_system", "component_library"],

  "properties": {
    "meta": {
      "type": "object",
      "description": "Project identity and context",
      "required": ["project_name", "product_type", "target_market", "primary_language", "rtl", "prd_path", "generated_at", "nezam_version"],
      "properties": {
        "project_name":    { "type": "string" },
        "product_type":    { "type": "string", "enum": ["website", "webapp", "saas", "mobile", "tui"] },
        "target_market":   { "type": "string" },
        "primary_language":{ "type": "string" },
        "rtl":             { "type": "boolean", "description": "True when Arabic/RTL layout is required" },
        "prd_path":        { "type": "string" },
        "ia_path":         { "type": "string" },
        "content_path":    { "type": "string" },
        "generated_at":    { "type": "string", "format": "date-time" },
        "nezam_version":   { "type": "string" }
      }
    },

    "canvas_mode": {
      "type": "string",
      "enum": ["web-marketing", "saas-dashboard", "mobile-app", "tui"],
      "description": "Controls which component library and viewport rules the server loads"
    },

    "sitemap": {
      "type": "object",
      "description": "Full page hierarchy — drives the sitemap builder tab",
      "required": ["pages"],
      "properties": {
        "pages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "route", "type", "access"],
            "properties": {
              "id":       { "type": "string", "pattern": "^PAGE-[0-9]{3}$" },
              "title":    { "type": "string" },
              "route":    { "type": "string" },
              "type":     { "type": "string", "enum": ["public", "auth", "admin", "modal", "embed"] },
              "access":   { "type": "array", "items": { "type": "string" }, "description": "Persona IDs that can access this page" },
              "parent_id":{ "type": "string", "description": "Parent page ID for nested routes" },
              "children": { "type": "array", "items": { "type": "string" } },
              "feature_ids": { "type": "array", "items": { "type": "string" }, "description": "F-XXX feature spec IDs this page implements" },
              "ai_suggested_layout": { "type": "string", "description": "Agent's recommended layout block type" },
              "priority": { "type": "string", "enum": ["P0", "P1", "P2"] }
            }
          }
        },
        "navigation": {
          "type": "object",
          "properties": {
            "primary_nav_type": { "type": "string", "enum": ["top-bar", "sidebar", "bottom-tab", "hybrid", "none"] },
            "secondary_nav":    { "type": "boolean" },
            "breadcrumbs":      { "type": "boolean" },
            "mobile_nav_type":  { "type": "string", "enum": ["hamburger", "bottom-tab", "drawer", "none"] },
            "ai_suggestions": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Agent's nav structure recommendations with rationale"
            }
          }
        }
      }
    },

    "pages": {
      "type": "array",
      "description": "Per-page AI-suggested wireframe drafts",
      "items": {
        "type": "object",
        "required": ["page_id", "title", "route", "canvas_mode", "sections"],
        "properties": {
          "page_id":     { "type": "string" },
          "title":       { "type": "string" },
          "route":       { "type": "string" },
          "canvas_mode": { "type": "string" },
          "status":      { "type": "string", "enum": ["ai-draft", "in-review", "locked"] },
          "sections": {
            "type": "array",
            "description": "Ordered list of sections/blocks on this page",
            "items": {
              "type": "object",
              "required": ["section_id", "block_type", "order"],
              "properties": {
                "section_id":  { "type": "string" },
                "block_type":  { "type": "string", "description": "e.g. Nav_Sidebar, Hero_Split, Dashboard_StatsRow" },
                "order":       { "type": "integer" },
                "props":       { "type": "object", "description": "Initial props the agent suggests for this block" },
                "ai_rationale":{ "type": "string", "description": "Why the agent chose this block" },
                "states": {
                  "type": "object",
                  "description": "All states this section must handle",
                  "properties": {
                    "loading": { "type": "string" },
                    "empty":   { "type": "string" },
                    "error":   { "type": "string" },
                    "populated":{ "type": "string" },
                    "offline": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },

    "design_system": {
      "type": "object",
      "description": "AI-suggested design token starting points — user can override all in the server",
      "properties": {
        "color_profile": {
          "type": "object",
          "properties": {
            "suggested_profile": { "type": "string", "description": "e.g. 'SaaS Minimalist', 'Egyptian Fintech', 'Dark Pro'" },
            "primary":     { "type": "string" },
            "secondary":   { "type": "string" },
            "accent":      { "type": "string" },
            "background":  { "type": "string" },
            "surface":     { "type": "string" },
            "text_primary":{ "type": "string" },
            "text_muted":  { "type": "string" },
            "success":     { "type": "string" },
            "warning":     { "type": "string" },
            "error":       { "type": "string" },
            "border":      { "type": "string" }
          }
        },
        "typography": {
          "type": "object",
          "properties": {
            "heading_font":  { "type": "string" },
            "body_font":     { "type": "string" },
            "mono_font":     { "type": "string" },
            "base_size_px":  { "type": "integer" },
            "scale_ratio":   { "type": "string", "description": "e.g. 'major-third' (1.25), 'perfect-fourth' (1.333)" },
            "line_height":   { "type": "number" }
          }
        },
        "spacing": {
          "type": "object",
          "properties": {
            "base_unit_px": { "type": "integer", "enum": [4, 8], "description": "Grid baseline" },
            "density":      { "type": "string", "enum": ["compact", "default", "comfortable"] }
          }
        },
        "borders": {
          "type": "object",
          "properties": {
            "radius_style": { "type": "string", "enum": ["sharp", "subtle", "rounded", "pill"] },
            "shadow_depth": { "type": "string", "enum": ["flat", "subtle", "medium", "elevated"] }
          }
        },
        "grid": {
          "type": "object",
          "properties": {
            "system":   { "type": "string", "enum": ["12-column", "flexbox", "masonry", "asymmetric"] },
            "max_width_px": { "type": "integer" },
            "gutter_px":    { "type": "integer" }
          }
        },
        "dark_mode": { "type": "boolean" },
        "motion": {
          "type": "object",
          "properties": {
            "preset":      { "type": "string", "enum": ["none", "subtle", "standard", "expressive"] },
            "duration_ms": { "type": "integer" },
            "easing":      { "type": "string" }
          }
        }
      }
    },

    "component_library": {
      "type": "object",
      "description": "Which blocks are available on the canvas — filtered by canvas_mode",
      "properties": {
        "navigation":  { "type": "array", "items": { "type": "string" } },
        "headers":     { "type": "array", "items": { "type": "string" } },
        "heroes":      { "type": "array", "items": { "type": "string" } },
        "sidebars":    { "type": "array", "items": { "type": "string" } },
        "footers":     { "type": "array", "items": { "type": "string" } },
        "sections":    { "type": "array", "items": { "type": "string" } },
        "cards":       { "type": "array", "items": { "type": "string" } },
        "grids":       { "type": "array", "items": { "type": "string" } },
        "forms":       { "type": "array", "items": { "type": "string" } },
        "dashboards":  { "type": "array", "items": { "type": "string" } },
        "charts":      { "type": "array", "items": { "type": "string" } },
        "tables":      { "type": "array", "items": { "type": "string" } },
        "modals":      { "type": "array", "items": { "type": "string" } },
        "mobile_primitives": { "type": "array", "items": { "type": "string" } },
        "tui_blocks":  { "type": "array", "items": { "type": "string" } }
      }
    },

    "ai_notes": {
      "type": "array",
      "description": "Agent annotations visible in the server UI — guidance for the user",
      "items": {
        "type": "object",
        "properties": {
          "type":    { "type": "string", "enum": ["suggestion", "warning", "requirement", "rationale"] },
          "target":  { "type": "string", "description": "page_id or section_id this note applies to" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
