{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "nezam:wireframe-server:wireframes_locked:1.0.0",
  "title": "NEZAM Wireframe Server — Locked Wireframes (Server → Agent)",
  "description": "Generated by the wireframe server after the user has finished their design session. Read by developer agents as the authoritative UI contract. Nothing in this file may be overridden without a new wireframe session.",

  "type": "object",
  "required": ["meta", "locked_at", "design_decisions", "sitemap", "pages", "design_system"],

  "properties": {
    "meta": {
      "type": "object",
      "description": "Session and lock identity",
      "required": ["project_name", "session_id", "canvas_mode", "nezam_version", "locked_by"],
      "properties": {
        "project_name":    { "type": "string" },
        "session_id":      { "type": "string", "description": "UUID of the wireframe session that produced this lock" },
        "canvas_mode":     { "type": "string", "enum": ["web-marketing", "saas-dashboard", "mobile-app", "tui"] },
        "nezam_version":   { "type": "string" },
        "locked_by":       { "type": "string", "description": "Email or identifier of the user who approved the lock" },
        "source_context":  { "type": "string", "description": "Path to the project_context.json that seeded this session" }
      }
    },

    "locked_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the user clicked Lock & Export"
    },

    "design_decisions": {
      "type": "object",
      "description": "High-level design decisions made during the session — required reading before any UI implementation",
      "properties": {
        "nav_structure": {
          "type": "object",
          "properties": {
            "primary_nav_type":   { "type": "string", "enum": ["top-bar", "sidebar", "bottom-tab", "hybrid", "none"] },
            "mobile_nav_type":    { "type": "string", "enum": ["hamburger", "bottom-tab", "drawer", "none"] },
            "secondary_nav":      { "type": "boolean" },
            "breadcrumbs":        { "type": "boolean" },
            "sidebar_collapsible":{ "type": "boolean" },
            "sidebar_default":    { "type": "string", "enum": ["expanded", "collapsed", "icon-only"] },
            "rationale":          { "type": "string" }
          }
        },
        "visual_style": {
          "type": "string",
          "description": "Short label the user chose or confirmed — e.g. 'Dark Pro SaaS', 'Egyptian Fintech', 'Clean Minimal'"
        },
        "layout_direction": {
          "type": "string",
          "enum": ["ltr", "rtl"],
          "description": "Confirmed layout direction for the entire app"
        },
        "page_density":   { "type": "string", "enum": ["compact", "default", "comfortable"] },
        "color_mode":     { "type": "string", "enum": ["light-only", "dark-only", "auto", "user-toggle"] },
        "motion_level":   { "type": "string", "enum": ["none", "subtle", "standard", "expressive"] },
        "user_notes":     { "type": "string", "description": "Freeform notes the user typed during the session" }
      }
    },

    "sitemap": {
      "type": "object",
      "description": "Final approved sitemap — this is the canonical page list for development",
      "required": ["pages"],
      "properties": {
        "pages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "title", "route", "type", "access", "status"],
            "properties": {
              "id":       { "type": "string", "pattern": "^PAGE-[0-9]{3}$" },
              "title":    { "type": "string" },
              "route":    { "type": "string" },
              "type":     { "type": "string", "enum": ["public", "auth", "admin", "modal", "embed"] },
              "access":   { "type": "array", "items": { "type": "string" }, "description": "Persona IDs approved to access this page" },
              "status":   { "type": "string", "enum": ["approved", "deferred", "removed"], "description": "User's decision on this page" },
              "parent_id":{ "type": "string" },
              "children": { "type": "array", "items": { "type": "string" } },
              "feature_ids":     { "type": "array", "items": { "type": "string" } },
              "nav_label":       { "type": "string", "description": "Exact label to use in navigation — copy-locked" },
              "nav_icon":        { "type": "string", "description": "Icon name from the approved icon set" },
              "show_in_nav":     { "type": "boolean" },
              "nav_position":    { "type": "integer", "description": "Order in the navigation list" },
              "breadcrumb_trail":{ "type": "array", "items": { "type": "string" }, "description": "Exact breadcrumb labels from root to this page" },
              "priority":        { "type": "string", "enum": ["P0", "P1", "P2"] },
              "user_comment":    { "type": "string", "description": "Anything the user typed in the page comment field" }
            }
          }
        }
      }
    },

    "pages": {
      "type": "array",
      "description": "Per-page locked wireframe specifications — one entry per approved page",
      "items": {
        "type": "object",
        "required": ["page_id", "title", "route", "canvas_mode", "layout_approved", "sections"],
        "properties": {
          "page_id":         { "type": "string", "pattern": "^PAGE-[0-9]{3}$" },
          "title":           { "type": "string" },
          "route":           { "type": "string" },
          "canvas_mode":     { "type": "string" },
          "layout_approved": { "type": "boolean", "description": "User explicitly clicked Approve on this page" },
          "thumbnail_path":  { "type": "string", "description": "Relative path to PNG screenshot of the approved wireframe" },
          "user_comment":    { "type": "string" },

          "sections": {
            "type": "array",
            "description": "Ordered, approved sections — developer must implement these blocks in this order",
            "items": {
              "type": "object",
              "required": ["section_id", "block_type", "order", "approved"],
              "properties": {
                "section_id":    { "type": "string" },
                "block_type":    { "type": "string", "description": "Exact block name from the component library" },
                "order":         { "type": "integer" },
                "approved":      { "type": "boolean" },
                "locked_props": {
                  "type": "object",
                  "description": "Props the user explicitly set — cannot be changed by the developer without approval",
                  "additionalProperties": true
                },
                "flexible_props": {
                  "type": "object",
                  "description": "Props the user left as suggestions — developer has discretion within design tokens",
                  "additionalProperties": true
                },
                "content_slots": {
                  "type": "object",
                  "description": "Named text/image slots with the user's approved content",
                  "additionalProperties": {
                    "type": "object",
                    "properties": {
                      "value":    { "type": "string" },
                      "locked":   { "type": "boolean", "description": "If true, this copy is final — no AI rewriting" },
                      "type":     { "type": "string", "enum": ["text", "heading", "image", "icon", "list", "richtext"] }
                    }
                  }
                },
                "states_approved": {
                  "type": "object",
                  "description": "Which states the user reviewed and approved for this section",
                  "properties": {
                    "loading":   { "type": "boolean" },
                    "empty":     { "type": "boolean" },
                    "error":     { "type": "boolean" },
                    "populated": { "type": "boolean" },
                    "offline":   { "type": "boolean" }
                  }
                },
                "user_comment":  { "type": "string" }
              }
            }
          },

          "responsive_decisions": {
            "type": "object",
            "description": "How this page behaves at each breakpoint — user-reviewed",
            "properties": {
              "mobile": {
                "type": "object",
                "properties": {
                  "layout_variant":  { "type": "string", "description": "Which layout the user approved for mobile" },
                  "hidden_sections": { "type": "array", "items": { "type": "string" }, "description": "section_ids hidden on mobile" },
                  "stacked_sections":{ "type": "array", "items": { "type": "string" } }
                }
              },
              "tablet": {
                "type": "object",
                "properties": {
                  "layout_variant":  { "type": "string" },
                  "hidden_sections": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },

    "design_system": {
      "type": "object",
      "description": "FINAL design token values — these are the source of truth for DESIGN.md generation",
      "required": ["color_profile", "typography", "spacing", "borders"],
      "properties": {
        "color_profile": {
          "type": "object",
          "required": ["profile_name", "primary", "secondary", "accent", "background", "surface", "text_primary", "text_muted", "success", "warning", "error", "border"],
          "properties": {
            "profile_name":  { "type": "string", "description": "Name of the color profile chosen — e.g. 'Dark Pro', 'Egyptian Fintech'" },
            "primary":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "primary_hover": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "secondary":     { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "accent":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "background":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "surface":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "surface_raised":{ "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "text_primary":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "text_secondary":{ "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "text_muted":    { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "text_on_primary":{ "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "success":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "warning":       { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "error":         { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "border":        { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "border_strong": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
            "dark_mode_overrides": {
              "type": "object",
              "description": "Token overrides when dark mode is active — only fields that differ from light mode",
              "additionalProperties": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" }
            }
          }
        },

        "typography": {
          "type": "object",
          "required": ["heading_font", "body_font", "base_size_px", "scale_ratio", "line_height"],
          "properties": {
            "heading_font":   { "type": "string", "description": "Exact Google Fonts or system font name" },
            "body_font":      { "type": "string" },
            "mono_font":      { "type": "string" },
            "arabic_font":    { "type": "string", "description": "Required when rtl is true" },
            "base_size_px":   { "type": "integer" },
            "scale_ratio":    { "type": "string", "description": "e.g. major-third (1.25), perfect-fourth (1.333), minor-third (1.2)" },
            "scale_ratio_value": { "type": "number" },
            "line_height":    { "type": "number" },
            "heading_weight": { "type": "integer", "enum": [400, 500, 600, 700, 800, 900] },
            "body_weight":    { "type": "integer", "enum": [300, 400, 500] },
            "font_load_strategy": { "type": "string", "enum": ["google-fonts", "local", "system-stack"] }
          }
        },

        "spacing": {
          "type": "object",
          "required": ["base_unit_px", "density"],
          "properties": {
            "base_unit_px": { "type": "integer", "enum": [4, 8] },
            "density":      { "type": "string", "enum": ["compact", "default", "comfortable"] },
            "scale": {
              "type": "object",
              "description": "Named spacing tokens derived from base unit",
              "properties": {
                "xs":  { "type": "integer" },
                "sm":  { "type": "integer" },
                "md":  { "type": "integer" },
                "lg":  { "type": "integer" },
                "xl":  { "type": "integer" },
                "2xl": { "type": "integer" },
                "3xl": { "type": "integer" }
              }
            }
          }
        },

        "borders": {
          "type": "object",
          "required": ["radius_style", "shadow_depth"],
          "properties": {
            "radius_style":  { "type": "string", "enum": ["sharp", "subtle", "rounded", "pill"] },
            "radius_values": {
              "type": "object",
              "properties": {
                "sm":  { "type": "string" },
                "md":  { "type": "string" },
                "lg":  { "type": "string" },
                "full":{ "type": "string" }
              }
            },
            "shadow_depth":  { "type": "string", "enum": ["flat", "subtle", "medium", "elevated"] },
            "shadow_values": {
              "type": "object",
              "properties": {
                "sm":  { "type": "string" },
                "md":  { "type": "string" },
                "lg":  { "type": "string" },
                "xl":  { "type": "string" }
              }
            },
            "border_width_default": { "type": "integer", "description": "in px" }
          }
        },

        "grid": {
          "type": "object",
          "properties": {
            "system":       { "type": "string", "enum": ["12-column", "flexbox", "masonry", "asymmetric"] },
            "max_width_px": { "type": "integer" },
            "gutter_px":    { "type": "integer" },
            "column_count": { "type": "integer" }
          }
        },

        "motion": {
          "type": "object",
          "properties": {
            "preset":       { "type": "string", "enum": ["none", "subtle", "standard", "expressive"] },
            "duration_ms":  { "type": "integer" },
            "easing":       { "type": "string" },
            "reduced_motion_respect": { "type": "boolean", "description": "Must be true — respects prefers-reduced-motion" }
          }
        },

        "icon_set": {
          "type": "string",
          "description": "The icon library approved for use — e.g. 'lucide', 'heroicons', 'phosphor', 'custom'"
        }
      }
    },

    "component_selections": {
      "type": "object",
      "description": "Which specific component variants the user approved per category",
      "properties": {
        "navigation_variant":    { "type": "string" },
        "header_variant":        { "type": "string" },
        "sidebar_variant":       { "type": "string" },
        "footer_variant":        { "type": "string" },
        "card_variant":          { "type": "string" },
        "table_variant":         { "type": "string" },
        "form_variant":          { "type": "string" },
        "dashboard_stats_variant":{ "type": "string" },
        "chart_types_approved":  { "type": "array", "items": { "type": "string" }, "description": "e.g. ['bar', 'line', 'donut'] — only these chart types are approved" },
        "modal_variant":         { "type": "string" },
        "toast_position":        { "type": "string", "enum": ["top-right", "top-center", "bottom-right", "bottom-center"] }
      }
    },

    "navigation_map": {
      "type": "object",
      "description": "Exact navigation structure — drives router and nav component implementation",
      "properties": {
        "primary_items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "route", "page_id"],
            "properties": {
              "label":    { "type": "string" },
              "route":    { "type": "string" },
              "page_id":  { "type": "string" },
              "icon":     { "type": "string" },
              "access":   { "type": "array", "items": { "type": "string" } },
              "badge":    { "type": "string", "description": "e.g. 'NEW', 'BETA', or null" },
              "children": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "label":   { "type": "string" },
                    "route":   { "type": "string" },
                    "page_id": { "type": "string" },
                    "icon":    { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "secondary_items": {
          "type": "array",
          "description": "Bottom of sidebar or secondary top-bar items",
          "items": {
            "type": "object",
            "properties": {
              "label":   { "type": "string" },
              "route":   { "type": "string" },
              "page_id": { "type": "string" },
              "icon":    { "type": "string" }
            }
          }
        },
        "user_menu_items": {
          "type": "array",
          "description": "Items in the user avatar dropdown",
          "items": {
            "type": "object",
            "properties": {
              "label":  { "type": "string" },
              "route":  { "type": "string" },
              "action": { "type": "string", "description": "e.g. 'logout', 'settings', 'profile'" }
            }
          }
        }
      }
    },

    "implementation_contract": {
      "type": "object",
      "description": "Explicit instructions for developer agents derived from this session",
      "properties": {
        "must_implement": {
          "type": "array",
          "description": "Non-negotiable implementation requirements extracted from user decisions",
          "items": { "type": "string" }
        },
        "must_not_implement": {
          "type": "array",
          "description": "Explicit prohibitions — features or patterns the user ruled out",
          "items": { "type": "string" }
        },
        "deferred_pages": {
          "type": "array",
          "description": "PAGE-XXX IDs the user marked as deferred — do not scaffold these",
          "items": { "type": "string" }
        },
        "design_md_generation": {
          "type": "object",
          "description": "Instructions for how to update DESIGN.md from this lock file",
          "properties": {
            "overwrite_tokens":  { "type": "boolean", "description": "If true, all tokens in DESIGN.md must be replaced with values from this file" },
            "overwrite_nav":     { "type": "boolean" },
            "overwrite_motion":  { "type": "boolean" }
          }
        }
      }
    },

    "session_stats": {
      "type": "object",
      "description": "Metadata about the wireframe session — for audit trail",
      "properties": {
        "session_duration_minutes": { "type": "integer" },
        "pages_reviewed":   { "type": "integer" },
        "pages_approved":   { "type": "integer" },
        "pages_deferred":   { "type": "integer" },
        "pages_removed":    { "type": "integer" },
        "blocks_changed":   { "type": "integer", "description": "How many blocks the user swapped or reordered" },
        "tokens_overridden":{ "type": "integer", "description": "How many design tokens the user changed from AI suggestions" },
        "comments_left":    { "type": "integer" }
      }
    }
  }
}
